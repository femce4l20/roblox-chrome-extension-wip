{
  "manifest_version": 3,
  "name": "Cvtmvtts Tweaker",
  "version": "1.0",
  "description": "Tweaks for various websites (just roblox rn :/)",
  "permissions": ["activeTab", "scripting"],
  "host_permissions": ["https://www.roblox.com/*"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Tweaker"
  },
  "content_scripts": [
  {
    "matches": ["*://*.roblox.com/*"],
    "js": [
      "Roblox/Modules/removeContent.js",
      "Roblox/roblox.js"
    ]
  }
],
  "web_accessible_resources": [
    {
      "resources": ["Roblox/Modules/*.js"],
      "matches": ["*://*.roblox.com/*"]
    }
  ]
}
